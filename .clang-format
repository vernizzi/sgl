---
Language:        Cpp
BasedOnStyle:    LLVM

# Indentation
UseTab:          Never
IndentWidth:     4
TabWidth:        4

# public:/private: flush with class keyword (one indent back from body)
AccessModifierOffset: -4

# Attach '*' and '&' to the type: e.g., 'const auto& self'
PointerAlignment: Left

# Reduce deep indentation on wrapped template/argument lists
AlignAfterOpenBracket: DontAlign

ContinuationIndentWidth: 4

# Braces on the same line
BreakBeforeBraces: Attach

# Reasonable line length
ColumnLimit:     160

# Modern C++ dialect for formatting decisions
Standard:        Auto

# Keep includes sorted
SortIncludes:    true

# ----------------------------------------------------
# Force braces on control statements and prevent
# single-line collapsing
# ----------------------------------------------------

# Automatically inserts missing braces around if, else, for, do, and while
InsertBraces:    true

# Allow empty blocks on a single line (e.g., no-op destructors)
# but force non-empty blocks to expand
AllowShortBlocksOnASingleLine: Empty

# Prevents short 'if' statements from staying on a single line
AllowShortIfStatementsOnASingleLine: Never

# Prevents short loops from staying on a single line
AllowShortLoopsOnASingleLine: false

# Enums always go to a new line
AllowShortEnumsOnASingleLine: false

# Allow trivial inline functions (getters, etc.) on a single line
AllowShortFunctionsOnASingleLine: Inline

# Ensures C++11 curly-brace initialization like auto a{b}; acts like expressions
# (Keeping short ones on one line, wrapping long ones)
Cpp11BracedListStyle: true
